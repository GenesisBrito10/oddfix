NODE_ENV=development
PORT=3001

DATABASE_URL="postgresql://oddfix_user:oddfix_pass@localhost:5433/oddfix_db?schema=public"

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Required in production (app refuses to boot without it). Use a long random value.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS: comma-separated allowlist. Required (and no "*") in production.
# In dev, leave empty to reflect the request origin.
CORS_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=true

# Rate limit for /auth/login and /auth/register only (not /surebets/current).
AUTH_THROTTLE_TTL_SECONDS=60
AUTH_THROTTLE_LIMIT=10

BETBURGER_ACCESS_TOKEN=
BETBURGER_API_BASE_URL=https://api-lv.betburger.com/api/v1
BETBURGER_REST_API_BASE_URL=https://rest-api-lv.betburger.com/api/v1

BETBURGER_LIVE_REST_API_BASE_URL=https://rest-api-lv.betburger.com/api/v1
BETBURGER_PREMATCH_REST_API_BASE_URL=https://rest-api-pr.betburger.com/api/v1

# /search_filters host per type (live = api-lv, prematch = api-pr).
BETBURGER_LIVE_API_BASE_URL=https://api-lv.betburger.com/api/v1
BETBURGER_PREMATCH_API_BASE_URL=https://api-pr.betburger.com/api/v1

BETBURGER_PRO_SEARCH_LOCALE=en
BETBURGER_PRO_SEARCH_PER_PAGE=10

BETBURGER_LIVE_SEARCH_FILTER_ID=1741103
BETBURGER_PREMATCH_SEARCH_FILTER_ID=1149524

BETBURGER_LIVE_SYNC_INTERVAL_MS=3000
BETBURGER_PREMATCH_SYNC_INTERVAL_MS=6000

BETBURGER_LIVE_LIMIT_PER_HOUR=1800
BETBURGER_PREMATCH_LIMIT_PER_HOUR=700

BETBURGER_LIVE_CURRENT_TTL_SECONDS=10
BETBURGER_LIVE_SNAPSHOT_TTL_SECONDS=60

BETBURGER_PREMATCH_CURRENT_TTL_SECONDS=20
BETBURGER_PREMATCH_SNAPSHOT_TTL_SECONDS=120

BETBURGER_LIVE_OPENING_PROFIT_TTL_SECONDS=600
BETBURGER_PREMATCH_OPENING_PROFIT_TTL_SECONDS=3600

BETBURGER_LIVE_REFRESH_LOCK_TTL_MS=2500
BETBURGER_PREMATCH_REFRESH_LOCK_TTL_MS=5000

BETBURGER_SCHEDULER_ENABLED=false

BETBURGER_HTTP_TIMEOUT_MS=10000
