# Frontend dev server port (keep off the backend's 3001)
PORT=3000

# Backend API origin — Nitro proxy forwards /auth, /users, /catalog, /surebets here
NUXT_API_PROXY_TARGET=http://localhost:3001

# Optional: bypass the proxy and call the API directly (leave empty to use the proxy)
# NUXT_PUBLIC_API_BASE=

# Desktop build only: backend origin baked into the Electron installer.
# ODDFIX_BACKEND_URL=https://api.seu-backend.com
